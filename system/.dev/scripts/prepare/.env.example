# Runtime
TZ=Asia/Almaty
COMPOSE_PROJECT_NAME=trimiata-events

# Absolute path to project root events storage (must exist on host)
# Example: /var/www/www-root/data/www/dev/bitrix-dev/system/events
EVENTS_DATA_ROOT=/var/www/www-root/data/www/dev/bitrix-dev/system/events

# ClickHouse
CLICKHOUSE_DB=trimiata_events
CLICKHOUSE_USER=events_user
CLICKHOUSE_PASSWORD=change_me_clickhouse_password
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# Collector placeholder
COLLECTOR_PORT=8081

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
