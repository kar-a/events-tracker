# Пример reverse-proxy для событийного контура (подставьте домен, пути к TLS, upstream-порты из .env).
# Grafana и collector по умолчанию слушают на хосте: ${GRAFANA_PORT}, ${COLLECTOR_PORT}.

server {
	listen 443 ssl http2;
	server_name events.trimiata.ru;

	# ssl_certificate /path/to/fullchain.pem;
	# ssl_certificate_key /path/to/privkey.pem;

	location /grafana/ {
		proxy_pass http://127.0.0.1:3000/;
		proxy_set_header Host $host;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
	}

	location /collector/ {
		proxy_pass http://127.0.0.1:8081/;
		proxy_set_header Host $host;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		client_max_body_size 2m;
	}
}
