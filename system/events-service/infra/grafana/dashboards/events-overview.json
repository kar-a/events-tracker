      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT event_type AS metric, count() AS value FROM ${CLICKHOUSE_DB:raw}.events_raw WHERE $__timeFilter(event_time) GROUP BY event_type ORDER BY value DESC LIMIT 20",
